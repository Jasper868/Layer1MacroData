# Copy this file to .env on each machine.
# Never commit .env.

# Optional. Usually not needed if you run commands from the repository root.
LAYER1_PROJECT_DIR=D:/InvestmentResearch/Layer1MacroDashboard

# Recommended default from this version onward:
# Leave LAYER1_DATA_DIR unset or comment it out, and the project will use:
#   <repo>/data
# This lets small daily CSV data be committed to GitHub and pulled on any machine.
# LAYER1_DATA_DIR=D:/InvestmentResearch/Layer1MacroDashboard/data

# Required for FRED downloads. Do not share your real key.
FRED_API_KEY=your_fred_api_key_here
